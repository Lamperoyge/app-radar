{
  "name": "app-radar",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Internal App Store intelligence: tracks top-grossing charts, release dates, and ratings velocity to surface newly released apps that are already monetizing.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm ci --prefix dashboard && npm run build --prefix dashboard",
    "build:server": "tsc -p tsconfig.json",
    "migrate": "tsx src/migrate.ts",
    "snapshot": "tsx src/snapshot-cli.ts",
    "dev:server": "tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
