# Postgres connection string. On Railway this is injected automatically when
# you reference the Postgres service (use ${{Postgres.DATABASE_URL}}).
DATABASE_URL=postgres://localhost:5432/app_radar

# Force SSL on/off for the DB connection. Unset = auto-detect
# (off for localhost / *.railway.internal, on otherwise).
# DATABASE_SSL=true

# HTTP port for the API + dashboard server.
PORT=8080

# Hour of day (UTC) the daily snapshot runs.
SNAPSHOT_HOUR_UTC=6

# Run a catch-up snapshot on process start if today's hasn't succeeded yet.
# Default true; set false to only run on the daily schedule.
RUN_ON_BOOT=true

# Override tracked countries (comma-separated ISO codes), e.g. for a quick
# local test run. Default: us,gb,de,au,ca
# COUNTRIES=us
